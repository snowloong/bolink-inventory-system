# 应用配置
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_DATABASE=bolink_inventory

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT配置
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES_IN=24h

# 限流配置
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# 跨域配置
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:1420

# 日志配置
LOG_LEVEL=debug 